<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="content-scroll-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.eventticketapp.gui.coordinatorControllers.eventManagement.EventHeaderController">

    <content>
        <VBox spacing="25.0" styleClass="main-content-container">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>

            <children>

                <!-- HEADER -->
                <VBox spacing="15.0">

                    <!-- BACK -->
                    <Button onAction="#handleBack" styleClass="btn-back" text="← Back to Events" />

                    <!-- TITLE + EDIT -->
                    <HBox alignment="CENTER_LEFT">
                        <children>

                            <Label fx:id="titleLabel" styleClass="display-title" HBox.hgrow="ALWAYS" />

                            <Region HBox.hgrow="ALWAYS" />

                            <Button fx:id="editButton" onAction="#handleEditEvent" styleClass="btn-edit-event" text="Edit" />
                        </children>
                    </HBox>

                    <!-- EVENT INFO -->
                    <VBox spacing="5.0">
                        <children>
                            <Label fx:id="dateLabel" styleClass="info-row" />
                            <Label fx:id="locationLabel" styleClass="info-row" />
                            <Label fx:id="coordinatorLabel" styleClass="info-row" />
                        </children>
                    </VBox>

                </VBox>

                <!-- TABS -->
                <HBox spacing="10.0" styleClass="tab-nav-container">
                    <children>
                        <Button fx:id="btnOverview" onAction="#handleTabChange" styleClass="tab-btn active" text="Overview" />

                        <Button fx:id="btnTicketTypes" onAction="#handleTabChange" styleClass="tab-btn" text="Ticket Types" />

                        <Button fx:id="btnIssueTickets" onAction="#handleTabChange" styleClass="tab-btn" text="Issue Tickets" />

                        <Button fx:id="btnIssuedTickets" onAction="#handleTabChange" styleClass="tab-btn" text="Issued Tickets" />
                    </children>
                </HBox>

                <!-- DYNAMIC CONTENT -->
                <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" />

            </children>
        </VBox>
    </content>
</ScrollPane>
