<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true"
            styleClass="content-scroll-pane"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="dk.easv.eventticketapp.gui.coordinatorControllers.eventManagement.CoordinatorEventOverviewController">

    <content>
        <VBox spacing="25.0" styleClass="main-content-container">

            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0"/>
            </padding>

            <children>

                <!-- ========================= -->
                <!-- EVENT DETAILS CARD -->
                <!-- ========================= -->
                <VBox spacing="15.0" styleClass="main-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>

                    <children>

                        <Label styleClass="card-title-small" text="Event Details"/>

                        <VBox spacing="10.0">

                            <VBox styleClass="detail-group">
                                <Label styleClass="detail-label" text="Description"/>
                                <Label fx:id="lblDescription"
                                       styleClass="detail-value"
                                       wrapText="true"/>
                            </VBox>

                        </VBox>

                    </children>
                </VBox>

                <!-- ========================= -->
                <!-- COORDINATORS CARD -->
                <!-- ========================= -->
                <VBox spacing="15.0" styleClass="main-card">
                    <padding>
                        <Insets bottom="25.0" left="25.0" right="25.0" top="25.0"/>
                    </padding>

                    <children>

                        <Label styleClass="card-title-small" text="Coordinators"/>

                        <ScrollPane fitToWidth="true"
                                    styleClass="content-scroll-pane">

                            <content>
                                <VBox fx:id="coordinatorContainer"
                                      spacing="12.0"/>
                            </content>

                        </ScrollPane>

                    </children>
                </VBox>

            </children>
        </VBox>
    </content>
</ScrollPane>