<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dk.easv.eventticketapp.gui.coordinatorControllers.eventManagement.TicketTypesController">

    <children>
        <!-- Header with Add Button -->
        <HBox alignment="CENTER_LEFT">
            <children>
                <VBox HBox.hgrow="ALWAYS">
                    <Label styleClass="section-title" text="Ticket Types" />
                    <Label styleClass="section-subtitle" text="Define different ticket categories for this event" />
                </VBox>
                <Button fx:id="btnAddTicketType" onAction="#onAddTicketType" styleClass="btn-primary" text="+ Add Ticket Type" />
            </children>
        </HBox>

        <!-- Stats Summary -->
        <HBox spacing="20.0">
            <children>
                <Label fx:id="lblTotalTypes" styleClass="stats-label" text="Total Types: 0" />
                <Label fx:id="lblTotalTickets" styleClass="stats-label" text="Total Tickets: 0" />
            </children>
        </HBox>

        <!-- Ticket Types Table -->
        <TableView fx:id="ticketTypesTable" styleClass="modern-table" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colName" text="Ticket Name" prefWidth="200">
                    <cellValueFactory>
                        <PropertyValueFactory property="name" />
                    </cellValueFactory>
                </TableColumn>

                <TableColumn fx:id="colPrice" text="Price" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="price" />
                    </cellValueFactory>
                    <cellFactory>
                        <Callback>
                            <TableColumn cellFactory="$priceCellFactory" />
                        </Callback>
                    </cellFactory>
                </TableColumn>

                <TableColumn fx:id="colQuantity" text="Available" prefWidth="120">
                    <cellValueFactory>
                        <PropertyValueFactory property="quantityAvailable" />
                    </cellValueFactory>
                </TableColumn>

                <TableColumn fx:id="colSold" text="Sold" prefWidth="100">
                    <cellValueFactory>
                        <PropertyValueFactory property="soldCount" />
                    </cellValueFactory>
                </TableColumn>

                <TableColumn fx:id="colStatus" text="Status" prefWidth="120">
                    <cellFactory>
                        <Callback>
                            <TableColumn cellFactory="$statusCellFactory" />
                        </Callback>
                    </cellFactory>
                </TableColumn>

                <TableColumn fx:id="colActions" text="Actions" prefWidth="150">
                    <cellFactory>
                        <Callback>
                            <TableColumn cellFactory="$actionsCellFactory" />
                        </Callback>
                    </cellFactory>
                </TableColumn>
            </columns>

            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>

            <placeholder>
                <Label styleClass="placeholder-text" text="No ticket types defined yet. Click '+ Add Ticket Type' to create one." />
            </placeholder>
        </TableView>
    </children>
</VBox>