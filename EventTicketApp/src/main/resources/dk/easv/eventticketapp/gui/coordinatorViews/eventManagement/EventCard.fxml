<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" styleClass="event-card" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1"
fx:controller="dk.easv.eventticketapp.gui.coordinatorControllers.eventManagement.EventCardController">

    <padding>
        <Insets bottom="18" left="18" right="18" top="18" />
    </padding>

    <children>

        <!-- HEADER -->
        <HBox alignment="TOP_LEFT" spacing="10">

            <children>

                <!-- CLICKABLE CONTENT -->
                <VBox fx:id="clickArea" spacing="8" HBox.hgrow="ALWAYS">

                    <children>

                        <!-- TITLE + BADGE -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <children>
                                <Label fx:id="titleLabel" styleClass="event-card-title" />

                                <Label fx:id="lblOwner" styleClass="badge-owner" text="Owner" />
                            </children>
                        </HBox>

                        <!-- DATE -->
                        <Label fx:id="dateLabel" styleClass="event-detail-text" />

                        <!-- LOCATION -->
                        <Label fx:id="locationLabel" styleClass="event-detail-text" />

                        <!-- COORDINATORS -->
                        <Label fx:id="coordinatorLabel" styleClass="event-detail-text" />

                    </children>
                </VBox>

                <!-- DELETE BUTTON -->
                <Button onAction="#handleDelete" styleClass="icon-btn-delete" text="🗑" />

            </children>
        </HBox>

        <!-- DIVIDER -->
        <Separator styleClass="card-separator" />

        <!-- FOOTER -->
        <Label fx:id="ticketsLabel" styleClass="issued-text" text="0 tickets issued" />

    </children>
</VBox>
