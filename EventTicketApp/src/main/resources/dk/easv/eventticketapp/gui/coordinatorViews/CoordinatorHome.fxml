<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="content-scroll-pane" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dk.easv.eventticketapp.gui.coordinatorControllers.CoordinatorHomeController">

    <content>
        <VBox spacing="25.0" styleClass="main-content-container">
            <padding>
                <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
            </padding>

            <children>

                <!-- HEADER -->
                <HBox alignment="CENTER_LEFT">
                    <children>

                        <VBox HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="header-title" text="My Events" />
                                <Label styleClass="header-subtitle" text="Manage your assigned events" />
                            </children>
                        </VBox>

                        <HBox spacing="0.0" styleClass="toggle-container">
                            <children>
                                <Button onAction="#showEvents" styleClass="toggle-btn-left, active" text="📅 Events" />
                                <Button onAction="#showVouchers" styleClass="toggle-btn-right" text="🎫 Special Vouchers" />
                            </children>
                        </HBox>

                    </children>
                </HBox>

                <!-- ACTION BAR -->
                <HBox alignment="CENTER_LEFT" spacing="15.0">
                    <children>

                        <Button onAction="#createEventBtn" styleClass="create-btn" text="+ Create Event" />

                        <HBox alignment="CENTER_LEFT" styleClass="search-container" HBox.hgrow="ALWAYS">
                            <children>
                                <Label styleClass="search-icon" text="🔍" />
                                <TextField fx:id="txtFilter" promptText="Search events by name, location, or description..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>

                    </children>
                </HBox>

                <!-- 🔥 DYNAMIC EVENT CARDS -->
                <VBox fx:id="eventContainer" spacing="20.0" />

            </children>
        </VBox>
    </content>
</ScrollPane>
